{
  "manifest_version": 3,
  "name": "Second Brain",
  "version": "0.1.0",
  "description": "AI-powered semantic bookmark manager",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}